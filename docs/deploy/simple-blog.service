[Unit]
Description=Simple Blog Laravel Application
After=network.target

[Service]
Type=simple
WorkingDirectory=/srv/www/simpleblog
ExecStart=/usr/bin/php artisan serve --host=0.0.0.0 --port=8001
Restart=on-failure
RestartSec=5
# Small hardening: the service can never gain privileges it wasn't started with.
NoNewPrivileges=true

[Install]
WantedBy=default.target
